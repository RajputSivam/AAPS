84. Largest Rectangle in Histogram

Given an array of integers heights representing the histogram's bar height where the width of each bar is 1, return the area of the largest rectangle in the histogram.


//Optimal Approach

import java.util.Stack;

class Solution {
    public int largestRectangleArea(int[] heights) {
        int n = heights.length;
        Stack<Integer> st = new Stack<>();

        int[] leftSmaller  = new int[n];
        int[] rightSmaller = new int[n];

        // default values
        java.util.Arrays.fill(leftSmaller, -1);   // no smaller on left
        java.util.Arrays.fill(rightSmaller, n);   // no smaller on right

        // --- update leftSmaller array (left to right) ---
        for (int i = 0; i < n; i++) {
            // maintain monotonic increasing stack
            // remove elements >= heights[i]
            while (!st.isEmpty() && heights[st.peek()] >= heights[i])
                st.pop();

            // stack top is now the immediate smaller on left
            if (!st.isEmpty())
                leftSmaller[i] = st.peek();

            st.push(i);
        }

        // --- clear stack for reuse ---
        st.clear();

        // --- update rightSmaller array (right to left) ---
        for (int i = n - 1; i >= 0; i--) {
            while (!st.isEmpty() && heights[st.peek()] >= heights[i])
                st.pop();

            // stack top is now the immediate smaller on right
            if (!st.isEmpty())
                rightSmaller[i] = st.peek();

            st.push(i);
        }

        // --- find area for each bar and take maximum ---
        int maxArea = 0;
        for (int i = 0; i < n; i++) {
            maxArea = Math.max(maxArea,
                heights[i] * (rightSmaller[i] - leftSmaller[i] - 1));
        }

        return maxArea;
    }
}


//Brute force

class Solution {
    public int largestRectangleArea(int[] heights) {
        int n = heights.length;
        int maxArea = 0;

        for (int i = 0; i < n; i++) {

            // find immediate smaller on left
            int l = i - 1;
            while (l >= 0) {
                if (heights[l] >= heights[i])
                    l--;
                else
                    break;
            }

            // find immediate smaller on right
            int r = i + 1;
            while (r <= n - 1) {
                if (heights[r] >= heights[i])
                    r++;
                else
                    break;
            }

            // update max Area
            maxArea = Math.max(maxArea, heights[i] * (r - l - 1));
        }

        return maxArea;
    }
}


| Approach          | Time Complexity | Space Complexity |
| ----------------- | --------------- | ---------------- |
| ❌ Brute Force     | O(n³)           | O(1)             |
| ✅ Optimal (Stack) | O(n)            | O(n)             |

