
338. Counting Bits

Hint
Given an integer n, return an array ans of length n + 1 such that for each i (0 <= i <= n), ans[i] is the number of 1's in the binary representation of i.

mple 1:

Input: n = 2
Output: [0,1,1]
Explanation:
0 --> 0
1 --> 1
2 --> 10

class Solution {
    public int[] countBits(int n) {
        int []ar=new int[n+1];
        for(int i=0;i<=n;i++)
        {
            ar[i]=no( i );
        }
        return ar;   
    }
    public static int no(int n)
    {
        int c=0;
        while(n!=0)
        {
            if( n%2==1)
            {
                c++;
            }
            n=n/2;
        }
        return c;

    }

}
