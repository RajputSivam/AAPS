5. Longest Palindromic Substring

Given a string s, return the longest palindromic substring in s.


Example 1:

Input: s = "babad"
Output: "bab"
Explanation: "aba" is also a valid answer.


class Solution {
    public String longestPalindrome(String s) {
        int mx=Integer.MIN_VALUE;
        int start=0;
        int end=0;
        for(int i=0;i<s.length();i++)
        {
            for(int j=i;j<s.length();j++)
            {
                if( pal(s, i,j)==true)
                {
                    if( mx<(j-i+1) )
                    {
                        mx=(j-i+1);
                        start=i;
                        end=j;
                    }
                }
            }
        }
        return s.substring(start,end+1);
    }
    public static boolean pal(String s,int i,int j)
    {
        while(i<j)
        {
            if( s.charAt(i)!=s.charAt(j) )
            {
                return false;
            }
            i++;
            j--;
        }
        return true;
    }

}
Optimal

class Solution {
    public String longestPalindrome(String s) {
        int n = s.length();

        int start = 0;
        int end = 0;

        // check every character as center
        for (int i = 0; i < n; i++) {

            // odd length palindrome (center = i)
            int len1 = expandAroundCenter(s, i, i);

            // even length palindrome (center = i, i+1)
            int len2 = expandAroundCenter(s, i, i + 1);

            int len = Math.max(len1, len2);

            // update answer if longer palindrome found
            if (len > (end - start + 1)) {
                start = i - (len - 1) / 2;
                end = i + len / 2;
            }
        }

        return s.substring(start, end + 1);
    }

    // expand from center and return length of palindrome
    public int expandAroundCenter(String s, int left, int right) {
        while (left >= 0 && right < s.length()
                && s.charAt(left) == s.charAt(right)) {
            left--;
            right++;
        }

        // length of palindrome found
        return right - left - 1;
    }
}

|
| Approach                           | Idea                                    | Time Complexity (TC) | Space Complexity (SC) | Notes                             |
| ---------------------------------- | --------------------------------------- | -------------------- | --------------------- | --------------------------------- |
| **Brute Force**                    | Check all substrings + palindrome check | **O(n³)**            | **O(1)**              | Very slow, checks every substring |
| **Dynamic Programming**            | Store palindrome states in table        | **O(n²)**            | **O(n²)**             | Uses DP table `dp[i][j]`          |
| **Expand Around Center (Optimal)** | Expand from each center                 | **O(n²)**            | **O(1)**              | Most used in interviews           |
| **Manacher’s Algorithm (Best)**    | Linear time palindrome expansion trick  | **O(n)**             | **O(n)**              | Advanced, hardest but fastest     |
